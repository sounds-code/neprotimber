// --- SEO CONFIGURATION ---
const pageDescription = "Explore our premium selection of structural timber (Cypress, Pine, Blue Gum), custom machined moldings, roofing sheets, cement, and construction hardware at NEPRO Timbers & Hardware.";

// Generate JSON-LD Structured Data dynamically for the entire inventory catalogue
const allItems = categories.flatMap(cat => cat.items.map(item => ({
    "@type": "Product",
    "name": item.name,
    "description": item.desc,
    "image": item.image ? new URL(item.image, Astro.url.origin).toString() : undefined,
    "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "KES",
        "price": "Contact for pricing"
    }
})));

const jsonLdSchema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "HardwareStore",
            "@id": `${Astro.url.origin}/#organization`,
            "name": "NEPRO Timbers & Hardware",
            "url": Astro.url.origin,
            "description": "Premium timber yards and comprehensive construction hardware supplier.",
            "telephone": "+254712593434",
            "address": {
                "@type": "PostalAddress",
                "addressCountry": "KE",
                "addressRegion": "Nairobi"
            }
        },
        {
            "@type": "ItemPage",
            "@id": Astro.url.href,
            "url": Astro.url.href,
            "name": "Products | NEPRO Timbers & Hardware",
            "description": pageDescription,
            "mainEntity": {
                "@type": "ItemList",
                "numberOfItems": allItems.length,
                "itemListElement": allItems.map((prod, index) => ({
                    "@type": "ListItem",
                    "position": index + 1,
                    "item": prod
                }))
            }
        }
    ]
};
---

<Layout
        title="Products | Nepro Timbers & Hardware"
        description={pageDescription}
        schema={jsonLdSchema}
>
    <!-- NEW HERO - about-hero style -->
    <section class="about-hero">
        <div class="container hero-flex">
            <h1 class="script-title">Timber & Hardware</h1>
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a>
                <span aria-hidden="true">»</span>
                <span class="current-page">Products</span>
            </nav>
        </div>
    </section>

    <!-- Timber Header -->
    <div class="section-divider timber-divider animate-on-scroll">
        <div class="container">
            <h2 class="slide-right-to-left">Timber Collection</h2>
            <div class="animated-line timber-line"></div>
        </div>
    </div>

    {categories.map((cat, ci) => (
            <>
                {cat.isHardwareStart && (
                        <div class="hardware-3d-trigger animate-on-scroll">
                            <div class="section-divider hardware-divider">
                                <div class="container">
                                    <h2 class="slide-right-to-left">Construction Hardware</h2>
                                    <div class="animated-line hardware-line"></div>
                                </div>
                            </div>
                        </div>
                )}
                <section class={`category-section ${cat.theme === 'light' ? 'light-theme' : cat.theme === 'hardware' ? 'hardware-theme' : ci % 2 === 1 ? 'alt' : ''} ${cat.isHardwareStart ? 'hardware-reveal-3d' : ''}`} id={cat.id}>
                    <div class="container">
                        <div class="category-header stagger-in">
                            <span class="label">{cat.name.toUpperCase()}</span>
                            <h2>{cat.name}</h2>
                            <p class="cat-desc">{cat.desc}</p>
                        </div>
                        <div class="products-grid stagger-in">
                            {cat.items.map(item => {
                                return (
                                        <div class="product-card">
                                            <div class="product-img-wrapper">
                                                {item.image ? (
                                                        <div class="product-img">
                                                            <img
                                                                    src={item.image}
                                                                    alt={`${item.name} supplied by NEPRO Timbers & Hardware`}
                                                                    class="product-photo"
                                                                    data-lightbox={item.image}
                                                                    data-product={item.name}
                                                                    loading="lazy"
                                                                    decoding="async"
                                                            />
                                                            <button class="view-btn" data-lightbox={item.image} data-product={item.name} aria-label={`View full image of ${item.name}`}>
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                    <circle cx="11" cy="11" r="8"></circle>
                                                                    <path d="m21 21-4.35-4.35"></path>
                                                                </svg>
                                                            </button>
                                                        </div>
                                                ) : (
                                                        <div class="product-img">
                                                            <div class="product-img-placeholder">No Image</div>
                                                        </div>
                                                )}
                                            </div>
                                            {item.specs && item.specs.length > 0 && (
                                                    <div class="specs-badges">
                                                        {item.specs.map(spec => (
                                                                <span class="spec-badge">{spec}</span>
                                                        ))}
                                                    </div>
                                            )}
                                            <div class="product-info">
                                                <h3>{item.name}</h3>
                                                <p>{item.desc}</p>
                                                <div class="product-footer">
                                                    <span class="price">{item.price}</span>
                                                    <a
                                                            href={`https://wa.me/254712593434?text=Hi Nepro Timbers, I'm interested in ${item.name}`}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                            class="btn-enquire"
                                                    >
                                                        WhatsApp
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                );
                            })}
                        </div>
                    </div>
                </section>
            </>
    ))}

    <!-- LIGHTBOX MODAL -->
    <div class="lightbox-modal" id="lightbox-modal">
        <div class="lightbox-content">
            <button class="lightbox-close" id="lightbox-close">✕</button>
            <img id="lightbox-image" src="" alt="Product Showcase Fullscreen Layout" class="lightbox-image" />
            <div class="lightbox-info">
                <p id="lightbox-product-name"></p>
            </div>
        </div>
        <div class="lightbox-backdrop"></div>
    </div>

    <section class="products-cta">
        <div class="container">
            <h2>Can't find what you need?</h2>
            <p>We stock more than what's listed, from plumbing pipes to electrical fittings. Call or WhatsApp us and we'll sort you out.</p>
            <a href="https://wa.me/254712593434?text=Hi Nepro Timbers, I need help finding a product" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.85L.057 23.5l5.797-1.524A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.886 9.886 0 01-5.031-1.378l-.36-.214-3.742.981.999-3.648-.235-.374A9.861 9.861 0 012.106 12C2.106 6.535 6.535 2.106 12 2.106c5.466 0 9.894 4.429 9.894 9.894 0 5.466-4.428 9.894-9.894 9.894z"/>
                </svg>
                WhatsApp Us Now
            </a>
        </div>
    </section>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries: IntersectionObserverEntry[]) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    (entry.target as HTMLElement).classList.add('reveal-active');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.animate-on-scroll, .stagger-in, .hardware-3d-trigger').forEach(el => {
            observer.observe(el as HTMLElement);
        });

        const modal = document.getElementById('lightbox-modal') as HTMLElement;
        const modalImg = document.getElementById('lightbox-image') as HTMLImageElement;
        const modalName = document.getElementById('lightbox-product-name') as HTMLElement;
        const closeBtn = document.getElementById('lightbox-close') as HTMLElement;
        const backdrop = document.querySelector('.lightbox-backdrop') as HTMLElement;

        if (!modal || !modalImg || !modalName || !closeBtn) {
            console.error('Lightbox elements not found');
            return;
        }

        document.querySelectorAll('.view-btn').forEach((btn: Element) => {
            btn.addEventListener('click', (e: Event) => {
                e.preventDefault();
                const src = (btn as HTMLElement).getAttribute('data-lightbox');
                const name = (btn as HTMLElement).getAttribute('data-product');

                if (src && name) {
                    modalImg.src = src;
                    modalName.textContent = name;
                    modal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            });
        });

        closeBtn.addEventListener('click', () => {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        });

        backdrop?.addEventListener('click', () => {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        });

        modal.addEventListener('click', (e: Event) => {
            if (e.target === modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        document.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Escape' && modal.classList.contains('active')) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    });
</script>

<style>
    /* Custom layout-specific styles preserved accurately below */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    .about-hero {
        background: linear-gradient(135deg, #231802 0%, #d5a166 100%);
        padding: 3rem 0;
        border-bottom: none;
    }

    .hero-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 3rem;
    }

    .script-title {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
        font-weight: 300;
        color: #FFF;
        margin: 0;
        letter-spacing: -1px;
        line-height: 1.1;
        transition: all 0.4s ease;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 16px;
        white-space: nowrap;
    }

    .breadcrumb a {
        color: #FFF;
        text-decoration: none;
        transition: opacity 0.2s;
        font-weight: 500;
    }

    .breadcrumb a:hover {
        opacity: 0.8;
    }

    .breadcrumb span {
        color: rgba(255, 255, 255, 0.7);
    }

    .current-page {
        color: #FFF;
        font-weight: 500;
    }

    .hardware-3d-trigger {
        perspective: 1200px;
        overflow: visible;
    }

    .hardware-divider {
        opacity: 0;
        transform: translateZ(-200px) scale(0.8) rotateX(15deg);
        transition: all 1s cubic-bezier(0.34, 1.56, 0.64, 1);
        transform-origin: top center;
    }

    .hardware-3d-trigger.reveal-active .hardware-divider {
        opacity: 1;
        transform: translateZ(0) scale(1) rotateX(0deg);
    }

    .hardware-reveal-3d {
        opacity: 0;
        transform: translateY(50px) rotateX(-5deg);
        transition: all 1.2s cubic-bezier(0.23, 1, 0.32, 1) 0.2s;
    }

    .hardware-3d-trigger.reveal-active + .hardware-reveal-3d {
        opacity: 1;
        transform: translateY(0) rotateX(0deg);
    }

    .slide-right-to-left {
        opacity: 0;
        transform: translateX(100px);
        transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease;
    }
    .animated-line {
        width: 0;
