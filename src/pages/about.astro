<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Hero Sticky & Fade In Logic ---
        const aboutHero = document.getElementById('aboutHero');
        setTimeout(() => { aboutHero?.classList.add('visible'); }, 100);

        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                aboutHero?.classList.add('scrolled');
            } else {
                aboutHero?.classList.remove('scrolled');
            }
        });

        // --- 2. History Year Counter Logic ---
        const counterElement = document.getElementById('yearCounter');
        if (counterElement) {
            const startYear = 2017;
            const currentYear = new Date().getFullYear();
            let displayYear = startYear;
            let hasCounted = false;

            const countUp = () => {
                if (displayYear < currentYear) {
                    displayYear++;
                    counterElement.innerText = displayYear.toString();
                    setTimeout(countUp, 300);
                }
            };

            const observer = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting && !hasCounted) {
                    hasCounted = true;
                    setTimeout(countUp, 300);
                }
            });

            observer.observe(counterElement);
        }
    });
</script>