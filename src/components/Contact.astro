<script>
    // Form submission handler - WhatsApp Integration
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contactForm') as HTMLFormElement | null;

        if (form) {
            form.addEventListener('submit', async (e: Event) => {
                e.preventDefault();

                const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
                const originalText = submitBtn.innerHTML;

                // Show loading state
                submitBtn.innerHTML = `
          <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation: spin 1s linear infinite;">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
          <span>Opening WhatsApp...</span>
        `;
                submitBtn.disabled = true;

                // Get form data
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);

                // Format message for WhatsApp
                const message = `*New Contact Form Submission*

📝 *Name:* ${data.name}
📧 *Email:* ${data.email}
📱 *Phone:* ${data.phone}
🛒 *Product Interest:* ${data.product}

💬 *Message:*
${data.message}

${data.delivery ? '✅ Interested in delivery services' : ''}`;

                // Wait a moment for visual feedback
                await new Promise(resolve => setTimeout(resolve, 800));

                // Open WhatsApp with pre-filled message
                // IMPORTANT: Replace 254712345678 with your actual WhatsApp number
                const whatsappNumber = '+254712593434'; // ← UPDATE THIS!
                const whatsappURL = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;

                window.open(whatsappURL, '_blank');

                // Success state
                submitBtn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span>Opened WhatsApp!</span>
        `;
                submitBtn.style.background = '#25D366';

                // Reset form after 2 seconds
                setTimeout(() => {
                    form.reset();
                    submitBtn.innerHTML = originalText;
                    submitBtn.style.background = '';
                    submitBtn.disabled = false;
                }, 2000);
            });
        }
    });
</script>

<style>
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>