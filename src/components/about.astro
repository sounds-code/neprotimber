---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
    <section class="about-hero">
        <div class="container">
            <span class="label">WHO WE ARE</span>
            <h1>Built on Trust.<br/>Rooted in Ruiru.</h1>
            <p>Nepro Timbers & Hardware has been serving contractors, builders and homeowners in Ruiru Kimbo and across Kiambu County for over 10 years. We stock quality timber, hardware and offer custom cutting services — all under one roof.</p>
        </div>
    </section>

    <section class="about-values">
        <div class="container">
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3>Quality Guaranteed</h3>
                    <p>Every piece of timber is inspected before it leaves our yard. We only stock grades that meet construction standards.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3>Same Day Delivery</h3>
                    <p>Order before noon and we deliver same day within Ruiru Kimbo and surrounding areas in Kiambu County.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3>Local & Trusted</h3>
                    <p>We are part of this community. Our team knows the local building needs and we speak your language — literally.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round"/><circle cx="12" cy="12" r="3" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3>Custom Cutting</h3>
                    <p>Our Wood-Mizer LT40 handles precision cuts to your exact specifications. Bring your measurements, we handle the rest.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="about-cta">
        <div class="container">
            <h2>Come Visit Our Yard</h2>
            <p>Located in Ruiru Kimbo, Kiambu County. Open Monday–Saturday, 7AM–6PM.</p>
            <a href="https://wa.me/254700000000" target="_blank" class="btn-whatsapp">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.85L.057 23.5l5.797-1.524A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.886 9.886 0 01-5.031-1.378l-.36-.214-3.742.981.999-3.648-.235-.374A9.861 9.861 0 012.106 12C2.106 6.535 6.535 2.106 12 2.106c5.466 0 9.894 4.429 9.894 9.894 0 5.466-4.428 9.894-9.894 9.894z"/>
                </svg>
                WhatsApp Us
            </a>
        </div>
    </section>
</Layout>

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }
    .about-hero {
        background: #0A0A0A;
        border-left: 3px solid #C9A96E;
        padding: 8rem 0 5rem;
    }
    .label {
        font-size: 11px;
        color: #C9A96E;
        letter-spacing: 3px;
        display: block;
        margin-bottom: 1.5rem;
    }
    .about-hero h1 {
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: #FAFAF7;
        line-height: 1.2;
        margin-bottom: 1.5rem;
    }
    .about-hero p {
        font-size: 16px;
        color: #777;
        line-height: 1.8;
        max-width: 600px;
    }
    .about-values {
        background: #0f0f0f;
        padding: 5rem 0;
    }
    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
    }
    .value-card {
        background: #141414;
        border: 1px solid #1e1e1e;
        border-top: 2px solid #C9A96E;
        border-radius: 8px;
        padding: 2rem;
        transition: transform 0.2s, border-color 0.2s;
    }
    .value-card:hover {
        transform: translateY(-4px);
        border-color: rgba(201,169,110,0.4);
    }
    .value-icon {
        width: 40px;
        height: 40px;
        color: #C9A96E;
        margin-bottom: 1rem;
    }
    .value-icon svg { width: 100%; height: 100%; }
    .value-card h3 {
        font-size: 16px;
        font-weight: 500;
        color: #FAFAF7;
        margin-bottom: 0.75rem;
    }
    .value-card p {
        font-size: 14px;
        color: #666;
        line-height: 1.7;
    }
    .about-cta {
        background: #C9A96E;
        padding: 4rem 0;
        text-align: center;
    }
    .about-cta h2 {
        font-size: 2rem;
        font-weight: 700;
        color: #0A0A0A;
        margin-bottom: 0.75rem;
    }
    .about-cta p {
        font-size: 15px;
        color: #4a3a20;
        margin-bottom: 2rem;
    }
    .btn-whatsapp {
        background: #0A0A0A;
        color: #FAFAF7;
        padding: 13px 28px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border-radius: 2px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s, transform 0.2s;
    }
    .btn-whatsapp:hover {
        background: #1a1a1a;
        transform: scale(1.05);
    }
</style>